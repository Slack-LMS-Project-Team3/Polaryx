# Copy this file to `.env` at the repository root and fill real local/dev values.
# `.env` is git-ignored and must not be committed.

SECRET_KEY=replace-with-local-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=60000
CONNECTION_TIMEOUT=10

# MySQL
RDB_HOST=127.0.0.1
RDB_PORT=3306
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_NAME=replace-with-db-name

# MongoDB
NOSQL_HOST=127.0.0.1
NOSQL_PORT=27017
NOSQL_URL=mongodb://127.0.0.1:27017

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# GitHub OAuth
GITHUBS_CLIENT_ID=replace-with-github-client-id
GITHUBS_CLIENT_SECRET=replace-with-github-client-secret
GITHUBS_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# AWS S3
AWS_REGION=ap-northeast-2
AWS_BUCKET_NAME=replace-with-bucket
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key

# Web Push
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_EMAIL=mailto:dev@example.com
